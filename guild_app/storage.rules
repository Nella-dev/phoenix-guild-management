rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── [공통 함수] ──────────────────────────────────────────────
    // Firestore에서 유저 role 조회 (승인된 멤버인지 확인)
    function getUserRole() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      ).data.role;
    }

    function isApprovedMember() {
      return request.auth != null
        && getUserRole() in ['member', 'manager', 'admin'];
    }

    // ── 프로필 사진 ──────────────────────────────────────────────
    match /profile_photos/{userId} {

      // 읽기: 로그인한 승인 멤버만 열람 가능
      allow read: if request.auth != null && isApprovedMember();

      // 쓰기: 본인 + 승인된 멤버 + 파일 규격 검사
      allow write: if request.auth != null
                   && request.auth.uid == userId        // 반드시 본인만
                   && isApprovedMember()                // 승인 대기(pending) 제외
                   && request.resource.size < 2 * 1024 * 1024        // 2 MB 이하 (넉넉하게)
                   && request.resource.contentType in [               // 허용 형식만
                        'image/jpeg',
                        'image/jpg',
                        'image/png',
                        'image/webp'
                      ];

      // 삭제: 본인 또는 관리자만
      allow delete: if request.auth != null
                    && (request.auth.uid == userId || getUserRole() == 'admin');
    }

    // ── 기본 거부 (그 외 모든 경로) ──────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
